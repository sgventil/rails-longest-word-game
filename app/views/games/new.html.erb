<div class="container mx-5">
  <h1>New Game</h1>
  <% @letters.each do |letter| %>
    <div class="blue-cube"><strong><%= letter.upcase %></strong></div>
  <% end %>

  <div class="form-group">
    <form action="/score" method="post" data-turbo="false">
    <div class="text-left my-2 mx-1">
      <label for="word">Whats the longest word you can find?</label>
    </div>
      <div class="d-flex justify-content-center align-items-center">
        <%= hidden_field_tag 'letters', @letters %>
        <input type="text" id="word"  name="word" class="form-control mx-1" placeholder="Type the word">
        <button type="submit" class="btn btn-outline-dark"><strong>Play</strong></button>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      </div>
    </form>
  </div>
</div>
